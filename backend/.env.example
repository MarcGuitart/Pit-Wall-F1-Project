# ── Copy this file to .env and fill in values. Never commit .env. ──────────

# OpenF1 API (free, no auth required for historical sessions)
OPENF1_BASE_URL=https://api.openf1.org/v1

# Where to store per-session JSON cache files
# Note: ephemeral on Render free tier — cache resets on container restart
CACHE_DIR=./cache

# Allowed CORS origins (comma-separated, no spaces)
# Local development:
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production example:
# CORS_ORIGINS=https://your-app.vercel.app

# Environment flag
ENVIRONMENT=development

# ── AI chat (both are optional — the app works without them) ────────────────

# Ollama (local) — use 127.0.0.1 to avoid IPv6 resolution issues
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# Groq (free cloud fallback) — get key at console.groq.com
# If set, Groq is used when Ollama is unavailable (useful for production)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
