# OpenF1 API (free, no auth required for historical sessions)
OPENF1_BASE_URL=https://api.openf1.org/v1

# Where to store per-session JSON cache files
CACHE_DIR=./cache

# Ollama server for the race engineer AI chat
# Use 127.0.0.1 (not localhost) to avoid IPv6 resolution issues on some systems
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
